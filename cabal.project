packages:
  ghc-stack-profiler/
  ghc-stack-profiler-core/
  ghc-stack-profiler-speedscope/

optional-packages:
  examples/simple/
  examples/simple-scope/

if !os(windows)
  optional-package:
    examples/eventlog-socket-example/

  -- In this project, we always build with '+control' on non-windows
  package ghc-stack-profiler
    flags: +control

  package eventlog-socket
    flags: +control

if impl(ghc >=9.14)
  allow-newer:
    base,
    template-haskell,
    ghc-bignum,
    containers,
